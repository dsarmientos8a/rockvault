@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <p class="eyebrow">🎸 RockVault · 100% Volumen</p>

    <h1 class="hero-title">BIBLIOTECA DE<br />MÚSICA ROCK</h1>

    <div class="pass-card" aria-label="Ficha del proyecto">
        <p><span class="label">Curso:</span> Sistemas Operativos I</p>
        <p><span class="label">Fase:</span> Proyecto Final ASP.NET MVC con .NET 9</p>
        <p><span class="label">Integrantes:</span> David Sarmientos Ochoa / Luis Fernando Ortiz Hernandez</p>
        <p><span class="label">Estado:</span> Versión 1</p>
        <p class="pass-sub">ASP.NET Core 9.0 · Biblioteca Interactiva de Rock &amp; Bandas</p>
    </div>

    <h2 class="feature-heading">TODO EN UN SOLO ESPACIO</h2>
    <p class="bounce-arrow" aria-hidden="true">👇</p>

    <div class="media-feature">
        <svg class="vinyl" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Disco de vinilo brillando con luces neón">
            <circle cx="100" cy="100" r="98" fill="#0a0a12" stroke="#ff2ec4" stroke-width="2" />
            <circle cx="100" cy="100" r="82" fill="none" stroke="#ffffff" stroke-opacity="0.06" stroke-width="1" />
            <circle cx="100" cy="100" r="66" fill="none" stroke="#ffffff" stroke-opacity="0.06" stroke-width="1" />
            <circle cx="100" cy="100" r="50" fill="none" stroke="#ffffff" stroke-opacity="0.06" stroke-width="1" />
            <circle cx="100" cy="100" r="34" fill="#39ff88" />
            <circle cx="100" cy="100" r="34" fill="none" stroke="#2af5ff" stroke-width="3" />
            <circle cx="100" cy="100" r="4" fill="#0a0a12" />
        </svg>

        <div class="equalizer" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
        </div>

        <a class="cta-button" asp-controller="Home" asp-action="Catalogo">🎧 Explorar Catálogo</a>
    </div>
</section>
